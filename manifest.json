{
  "manifest_version": 3,
  "name": "Volume Booster",
  "description": "Boost audio and video volume up to 600% on the current tab.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Volume Booster"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
